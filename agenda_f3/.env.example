# =============================================================================
# agenda_f3 — variáveis de ambiente
# Destino na VM: /opt/agenda_f3/.env (chmod 600)
# Este arquivo (.env.example) NÃO contém segredos — só placeholders.
# =============================================================================

# ── Flask ─────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME

# ── IDCAMIM OIDC ──────────────────────────────────────────────────────────────
# Sistema "agendadodia_f3" registrado em auth.camim.com.br/painel/sistemas
IDCAMIM_CLIENT_ID=CHANGE_ME
IDCAMIM_CLIENT_SECRET=CHANGE_ME
IDCAMIM_REDIRECT_URI=https://camila2.ia.camim.com.br/auth/callback

# ── Postgres RDS (database "f3" — backup + fonte primária da app) ────────────
# Mesmas creds do relatorio_h_t, só muda o database name.
PG_RDS_HOST=postgres-db.c54qviwhydc0.us-east-1.rds.amazonaws.com
PG_RDS_PORT=9432
PG_RDS_DB_F3=f3
PG_RDS_USER=camim_pg
PG_RDS_PASSWORD=CHANGE_ME
PG_RDS_SSLMODE=require

# ── SQL Server CAMIM (13 postos) ──────────────────────────────────────────────
# Copiar bloco DB_HOST_X / DB_BASE_X / DB_USER_X / DB_PASSWORD_X / DB_PORT_X
# de /opt/relatorio_h_t/.env. Postos: A B C D G I J M N P R X Y
ODBC_DRIVER=ODBC Driver 17 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_CERT=yes
DB_TIMEOUT=20

# Exemplo (posto A — Anchieta):
# DB_USER_A=IA_API_Consultas
# DB_PASSWORD_A=...
# DB_BASE_A=anchieta
# DB_HOST_A=anchieta.ddns.me
# DB_PORT_A=14433
