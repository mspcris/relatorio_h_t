# /opt/camila2/.env  — NÃO commitar valores reais

# OBRIGATÓRIO: deve ser IGUAL ao SECRET_KEY do camim-auth (KPI), senão as
# sessões não são compartilhadas.
SECRET_KEY=

# Default: appsess (igual ao KPI). Não mudar a menos que mude no KPI também.
SESS_NAME=appsess
SESS_TTL_SECONDS=28800

# Base do KPI pra redirects (login, admin)
KPI_BASE_URL=https://kpi.camim.com.br
